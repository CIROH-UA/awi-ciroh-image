#!/bin/bash
set -euo pipefail

# install nbfetch
jupyter server extension enable --py nbfetch --sys-prefix

# install uv
curl -LsSf https://astral.sh/uv/install.sh | UV_INSTALL_DIR=/home/jovyan/.local/bin sh

# install pixi
curl -fsSL https://pixi.sh/install.sh | PIXI_HOME=/home/jovyan/.local bash

# add pixi and uv to PATH
echo 'export PATH="/home/jovyan/.local/bin:$PATH""' >>/home/jovyan/.bashrc

# add some aliases
echo "alias ll='ls -alF'" >>~/.bashrc
